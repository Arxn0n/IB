import random

def generate_gamma(length, N):
    return [random.randint(0, N - 1) for _ in range(length)]

def encrypt(plaintext, gamma, N):
    ciphertext = []
    
    for i, char in enumerate(plaintext):
        if char.isalpha():  # Шифруем только буквы
            # Находим индекс буквы
            index = ord(char.upper()) - ord('А')
            # Шифруем с использованием гаммы
            encrypted_index = (index + gamma[i]) % N
            ciphertext.append(chr(encrypted_index + ord('А')))
        else:
            ciphertext.append(char)  # Оставляем символы без изменений

    return ''.join(ciphertext)

def decrypt(ciphertext, gamma, N):
    plaintext = []
    
    for i, char in enumerate(ciphertext):
        if char.isalpha(): 
            # Находим индекс зашифрованной буквы
            index = ord(char.upper()) - ord('А')
            # Расшифровываем с использованием гаммы
            # + N чтобы не мог быть отрицательным значением
            decrypted_index = (index - gamma[i] + N) % N
            plaintext.append(chr(decrypted_index + ord('А')))
        else:
            plaintext.append(char)  # Оставляем символы без изменений

    return ''.join(plaintext)

# Пример использования
plaintext = input("Введите текст для шифрования: ")
N = int(input("Введите значение N: "))
gamma = generate_gamma(len(plaintext.replace(" ", "")), N)  # Генерация гаммы

print("Гамма:\t\t\t", gamma)
# Шифрование
ciphertext = encrypt(plaintext, gamma, N)
print("Зашифрованный текст:\t", ciphertext)

# Расшифровка
decrypted_text = decrypt(ciphertext, gamma, N)
print("Расшифрованный текст:\t", decrypted_text)
